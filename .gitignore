# =========================================================================
# Unreal Engine .gitignore
# =========================================================================

# Visual Studio / Rider / VS Code user files
.vs/
.idea/

# Ignore VS Code folder except shared run/debug/build configs
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
!.vscode/settings.json
*.VC.db
*.VC.opendb
*.opensdf
*.sdf
*.suo
*.user
*.userosscache
*.sln.docstates
*.code-workspace

# Compiled source / build output
*.o
*.obj
*.pdb
*.exe
*.dll
*.lib
*.a
*.so
*.dylib
*.app
*.ipa
*.tlog

# =========================================================================
# Unreal Engine generated folders
# =========================================================================
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/
!Build/**/*.ico

# Plugin generated folders
Plugins/**/Binaries/
Plugins/**/Intermediate/

# Generated project files (regenerated by the engine)
*.sln
*.slnx
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.xcodeproj/
*.xcworkspace/

# =========================================================================
# Content that should NOT be ignored
# =========================================================================
# Keep config files
!Config/

# =========================================================================
# OS generated files
# =========================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# =========================================================================
# Misc
# =========================================================================
*.log
*.tmp
*.bak
